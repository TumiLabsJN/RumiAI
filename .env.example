# TikTok Competitor Analyzer - Environment Configuration

# Required: Apify Integration
APIFY_TOKEN=your_apify_token_here
MIN_VIEWS_THRESHOLD=10000
ANALYSIS_DAYS=30

# Required: Google Cloud Services (for video analysis)
# Using Workload Identity Federation - no key files needed!
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/home/jorge/.config/gcloud-workload-identity/simple-credential-config.json
GOOGLE_EXTERNAL_ACCOUNT_ALLOW_EXECUTABLES=1

# Required: Claude API (for AI insights)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_API_URL=https://api.anthropic.com/v1/messages

# Optional: Server Configuration
PORT=3001
NODE_ENV=development

# Optional: Rate Limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# Optional: Video Analysis Configuration
VIDEO_ANALYSIS_TIMEOUT=300000
MAX_CONCURRENT_JOBS=3
TEMP_DIR_CLEANUP_INTERVAL=3600000

# GerryOS Branding
COMPANY_NAME=GerryOS
COMPANY_LOGO_URL=images/Logo1.jpg
BRAND_COLOR=#8236FB